@model IEnumerable<SupplierServiceModel>
@{
    ViewData["Title"] = "Suppliers";
}
<div class="page-header">
    <h1><i class="bi bi-truck me-2"></i>Suppliers</h1>
    @if (User.IsInRole(RoleConstants.Administrator))
    {
        <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i> Add Supplier</a>
    }
</div>
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Products</th>
                @if (User.IsInRole(RoleConstants.Administrator))
                {
                    <th>Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var supplier in Model)
            {
                <tr>
                    <td class="fw-semibold">@supplier.Name</td>
                    <td><i class="bi bi-envelope me-1" style="color: var(--accent);"></i>@supplier.Email</td>
                    <td><i class="bi bi-telephone me-1" style="color: var(--green);"></i>@supplier.PhoneNumber</td>
                    <td><span class="badge bg-info">@supplier.ProductCount</span></td>
                    @if (User.IsInRole(RoleConstants.Administrator))
                    {
                        <td>
                            <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@supplier.Id"><i class="bi bi-pencil"></i></a>
                            <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@supplier.Id"><i class="bi bi-trash"></i></a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <div class="alert alert-info mt-3"><i class="bi bi-info-circle me-1"></i> No suppliers found.</div>
}
