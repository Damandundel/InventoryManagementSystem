@model IEnumerable<StockTransactionServiceModel>
@{
    ViewData["Title"] = "Stock Transactions";
}
<div class="page-header">
    <h1><i class="bi bi-arrow-left-right me-2"></i>Stock Transactions</h1>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i> New Transaction</a>
</div>
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Date</th>
                <th>Product</th>
                <th>Type</th>
                <th>Quantity</th>
                <th>Note</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var transaction in Model)
            {
                <tr class="clickable-row" data-href="@Url.Action("Details", "Products", new { id = transaction.ProductId })">
                    <td style="color: var(--text-2);">@transaction.CreatedOn.ToString("g")</td>
                    <td class="fw-semibold">
                        <a class="entity-link" asp-controller="Products" asp-action="Details" asp-route-id="@transaction.ProductId">@transaction.ProductName</a>
                    </td>
                    <td>
                        @if (transaction.Type == StockTransactionTypes.Add)
                        {
                            <span class="badge bg-success"><i class="bi bi-plus-circle"></i> Add</span>
                        }
                        else
                        {
                            <span class="badge bg-warning"><i class="bi bi-dash-circle"></i> Remove</span>
                        }
                    </td>
                    <td class="fw-semibold">
                        @(transaction.Type == StockTransactionTypes.Add ? "+" : "-")@transaction.QuantityChanged
                    </td>
                    <td style="color: var(--text-2);">@(string.IsNullOrWhiteSpace(transaction.Note) ? "—" : transaction.Note)</td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <div class="alert alert-info mt-3"><i class="bi bi-info-circle me-1"></i> No transactions found.</div>
}
