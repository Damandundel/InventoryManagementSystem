@model StockTransactionFormViewModel
@{
    ViewData["Title"] = "Create Stock Transaction";
}
<div class="page-header">
    <h1><i class="bi bi-plus-circle me-2" style="color: var(--accent);"></i>Create Stock Transaction</h1>
</div>
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label asp-for="ProductId" class="form-label"></label>
                        <select asp-for="ProductId" asp-items="@(new SelectList(Model.Products, "Id", "Name"))" class="form-select">
                            <option value="">-- Select Product --</option>
                        </select>
                        <span asp-validation-for="ProductId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Type" class="form-label"></label>
                        <select asp-for="Type" class="form-select">
                            <option value="@StockTransactionTypes.Add">Add Stock</option>
                            <option value="@StockTransactionTypes.Remove">Remove Stock</option>
                        </select>
                        <span asp-validation-for="Type" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Quantity" class="form-label"></label>
                        <input asp-for="Quantity" class="form-control" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Note" class="form-label"></label>
                        <textarea asp-for="Note" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Note" class="text-danger"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Save</button>
                        <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-x-lg me-1"></i> Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
