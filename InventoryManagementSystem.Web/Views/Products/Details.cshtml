@model ProductDetailsViewModel
@{
    ViewData["Title"] = Model.Name;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index"><i class="bi bi-box-seam me-1"></i>Products</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
    </ol>
</nav>

<div class="page-header">
    <h1><i class="bi bi-box-seam me-2" style="color: var(--accent);"></i>@Model.Name</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-success" asp-controller="StockTransactions" asp-action="Create" asp-route-productId="@Model.Id">
            <i class="bi bi-arrow-left-right me-1"></i> Adjust Stock
        </a>
        <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id"><i class="bi bi-pencil me-1"></i> Edit</a>
        <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model.Id"><i class="bi bi-trash me-1"></i> Delete</a>
        <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left me-1"></i> Back</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4 animate-in">
        <div class="stat-card stat-orange">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-label">Unit Price</div>
                    <div class="stat-value" style="font-size:1.3rem;">@Model.Price.ToString("C")</div>
                </div>
                <div class="stat-icon"><i class="bi bi-currency-dollar"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4 animate-in">
        <div class="stat-card @(Model.IsLowStock ? "stat-pink" : "stat-teal")">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-label">In Stock</div>
                    <div class="stat-value">@Model.Quantity.ToString("N0")</div>
                </div>
                <div class="stat-icon"><i class="bi bi-archive"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4 animate-in">
        <div class="stat-card stat-purple">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-label">Stock Value</div>
                    <div class="stat-value" style="font-size:1.3rem;">@Model.StockValue.ToString("C")</div>
                </div>
                <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
            </div>
        </div>
    </div>
</div>

@if (Model.IsLowStock)
{
    <div class="alert alert-danger d-flex align-items-center justify-content-between">
        <span><i class="bi bi-exclamation-triangle me-2"></i>This product is low on stock (@Model.Quantity remaining).</span>
        <a class="btn btn-sm btn-success" asp-controller="StockTransactions" asp-action="Create" asp-route-productId="@Model.Id">
            <i class="bi bi-plus-circle me-1"></i> Restock now
        </a>
    </div>
}

<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Product Information</h5>
    </div>
    <div class="card-body p-4">
        <dl class="row mb-0">
            <dt class="col-sm-3"><i class="bi bi-card-text me-1"></i> Description</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Description) ? "N/A" : Model.Description)</dd>
            <dt class="col-sm-3"><i class="bi bi-tag me-1"></i> Category</dt>
            <dd class="col-sm-9">
                <a class="entity-link" asp-controller="Categories" asp-action="Details" asp-route-id="@Model.CategoryId">
                    <span class="badge bg-info">@Model.CategoryName</span> <i class="bi bi-arrow-right" style="font-size:.7rem;"></i>
                </a>
            </dd>
            <dt class="col-sm-3"><i class="bi bi-truck me-1"></i> Supplier</dt>
            <dd class="col-sm-9">
                <a class="entity-link" asp-controller="Suppliers" asp-action="Details" asp-route-id="@Model.SupplierId">
                    @Model.SupplierName <i class="bi bi-arrow-right" style="font-size:.7rem;"></i>
                </a>
            </dd>
            <dt class="col-sm-3"><i class="bi bi-building me-1"></i> Warehouse</dt>
            <dd class="col-sm-9">
                <a class="entity-link" asp-controller="Warehouses" asp-action="Details" asp-route-id="@Model.WarehouseId">
                    @Model.WarehouseName <i class="bi bi-arrow-right" style="font-size:.7rem;"></i>
                </a>
            </dd>
        </dl>
    </div>
</div>

<div class="card">
    <div class="card-header bg-secondary text-white">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Stock Movement History</h5>
            <span class="badge bg-secondary">@Model.Transactions.Count() records</span>
        </div>
    </div>
    <div class="card-body p-0">
        @if (Model.Transactions.Any())
        {
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Quantity</th>
                        <th>Note</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Transactions)
                    {
                        <tr>
                            <td style="color: var(--text-2);">@t.CreatedOn.ToString("g")</td>
                            <td>
                                @if (t.Type == StockTransactionTypes.Add)
                                {
                                    <span class="badge bg-success"><i class="bi bi-plus-circle"></i> Add</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning"><i class="bi bi-dash-circle"></i> Remove</span>
                                }
                            </td>
                            <td class="fw-semibold">
                                @(t.Type == StockTransactionTypes.Add ? "+" : "-")@t.QuantityChanged
                            </td>
                            <td style="color: var(--text-2);">@(string.IsNullOrWhiteSpace(t.Note) ? "—" : t.Note)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-4 text-center" style="color: var(--text-3);">
                <i class="bi bi-clock-history" style="font-size:1.8rem;"></i>
                <p class="mb-0 mt-2">No stock movements recorded for this product yet.</p>
            </div>
        }
    </div>
</div>
