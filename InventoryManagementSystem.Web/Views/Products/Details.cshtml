@model ProductDetailsViewModel
@{
    ViewData["Title"] = Model.Name;
}
<div class="page-header">
    <h1><i class="bi bi-box-seam me-2" style="color: var(--accent);"></i>@Model.Name</h1>
</div>
<div class="card">
    <div class="card-body p-4">
        <dl class="row mb-0">
            <dt class="col-sm-3"><i class="bi bi-card-text me-1"></i> Description</dt>
            <dd class="col-sm-9">@(Model.Description ?? "N/A")</dd>
            <dt class="col-sm-3"><i class="bi bi-tag me-1"></i> Category</dt>
            <dd class="col-sm-9"><span class="badge bg-info">@Model.CategoryName</span></dd>
            <dt class="col-sm-3"><i class="bi bi-truck me-1"></i> Supplier</dt>
            <dd class="col-sm-9">@Model.SupplierName</dd>
            <dt class="col-sm-3"><i class="bi bi-building me-1"></i> Warehouse</dt>
            <dd class="col-sm-9">@Model.WarehouseName</dd>
            <dt class="col-sm-3"><i class="bi bi-currency-dollar me-1"></i> Price</dt>
            <dd class="col-sm-9 fw-bold" style="color: var(--accent);">@Model.Price.ToString("C")</dd>
            <dt class="col-sm-3"><i class="bi bi-box me-1"></i> Quantity</dt>
            <dd class="col-sm-9">
                @if (Model.Quantity < 10)
                {
                    <span class="badge bg-danger">@Model.Quantity</span>
                }
                else
                {
                    <span class="badge bg-success">@Model.Quantity</span>
                }
            </dd>
        </dl>
        <hr />
        <div class="d-flex gap-2">
            @if (User.IsInRole(RoleConstants.Administrator))
            {
                <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id"><i class="bi bi-pencil me-1"></i> Edit</a>
                <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model.Id"><i class="bi bi-trash me-1"></i> Delete</a>
            }
            <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left me-1"></i> Back to List</a>
        </div>
    </div>
</div>
