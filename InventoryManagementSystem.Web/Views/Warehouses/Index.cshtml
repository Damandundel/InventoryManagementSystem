@model IEnumerable<WarehouseServiceModel>
@{
    ViewData["Title"] = "Warehouses";
}
<div class="page-header">
    <h1><i class="bi bi-building me-2"></i>Warehouses</h1>
    @if (User.IsInRole(RoleConstants.Administrator))
    {
        <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i> Add Warehouse</a>
    }
</div>
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Location</th>
                <th>Products</th>
                @if (User.IsInRole(RoleConstants.Administrator))
                {
                    <th>Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var warehouse in Model)
            {
                <tr>
                    <td class="fw-semibold">@warehouse.Name</td>
                    <td><i class="bi bi-geo-alt me-1" style="color: var(--amber);"></i>@warehouse.Location</td>
                    <td><span class="badge bg-info">@warehouse.ProductCount</span></td>
                    @if (User.IsInRole(RoleConstants.Administrator))
                    {
                        <td>
                            <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@warehouse.Id"><i class="bi bi-pencil"></i></a>
                            <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@warehouse.Id"><i class="bi bi-trash"></i></a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <div class="alert alert-info mt-3"><i class="bi bi-info-circle me-1"></i> No warehouses found.</div>
}
