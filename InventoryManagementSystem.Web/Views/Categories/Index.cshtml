@model IEnumerable<CategoryServiceModel>
@{
    ViewData["Title"] = "Categories";
}
<div class="page-header">
    <h1><i class="bi bi-tags me-2"></i>Categories</h1>
    @if (User.IsInRole(RoleConstants.Administrator))
    {
        <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i> Add Category</a>
    }
</div>
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Products</th>
                @if (User.IsInRole(RoleConstants.Administrator))
                {
                    <th>Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td class="fw-semibold">@category.Name</td>
                    <td style="color: var(--text-2);">@(category.Description ?? "N/A")</td>
                    <td><span class="badge bg-info">@category.ProductCount</span></td>
                    @if (User.IsInRole(RoleConstants.Administrator))
                    {
                        <td>
                            <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@category.Id"><i class="bi bi-pencil"></i></a>
                            <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@category.Id"><i class="bi bi-trash"></i></a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <div class="alert alert-info mt-3"><i class="bi bi-info-circle me-1"></i> No categories found.</div>
}
