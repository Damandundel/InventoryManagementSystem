@{
    ViewData["Title"] = "404 - Not Found";
}
<div class="text-center mt-5 error-page">
    <div class="error-code">404</div>
    <h2 class="mt-3">Page Not Found</h2>
    <p class="lead text-muted">The page you are looking for does not exist or has been moved.</p>
    <a class="btn btn-primary btn-lg mt-3" asp-controller="Home" asp-action="Index">
        <i class="bi bi-house me-1"></i> Go Home
    </a>
</div>
