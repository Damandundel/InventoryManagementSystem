@{
    ViewData["Title"] = "400 - Bad Request";
}
<div class="text-center mt-5 error-page">
    <div class="error-code">400</div>
    <h2 class="mt-3">Bad Request</h2>
    <p class="lead text-muted">The request could not be understood by the server.</p>
    <a class="btn btn-primary btn-lg mt-3" asp-controller="Home" asp-action="Index">
        <i class="bi bi-house me-1"></i> Go Home
    </a>
</div>
