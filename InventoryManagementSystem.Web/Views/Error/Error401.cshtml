@{
    ViewData["Title"] = "401 - Unauthorized";
}
<div class="text-center mt-5 error-page">
    <div class="error-code">401</div>
    <h2 class="mt-3">Unauthorized</h2>
    <p class="lead text-muted">You do not have permission to access this page. Please log in with an authorized account.</p>
    <div class="d-flex gap-2 justify-content-center mt-3">
        <a class="btn btn-primary btn-lg" asp-controller="Account" asp-action="Login">
            <i class="bi bi-box-arrow-in-right me-1"></i> Login
        </a>
        <a class="btn btn-outline-secondary btn-lg" asp-controller="Home" asp-action="Index">
            <i class="bi bi-house me-1"></i> Go Home
        </a>
    </div>
</div>
