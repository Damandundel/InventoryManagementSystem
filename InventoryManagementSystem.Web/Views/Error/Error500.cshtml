@{
    ViewData["Title"] = "500 - Server Error";
}
<div class="text-center mt-5 error-page">
    <div class="error-code">500</div>
    <h2 class="mt-3">Internal Server Error</h2>
    <p class="lead text-muted">An unexpected error occurred. Please try again later.</p>
    <a class="btn btn-primary btn-lg mt-3" asp-controller="Home" asp-action="Index">
        <i class="bi bi-house me-1"></i> Go Home
    </a>
</div>
