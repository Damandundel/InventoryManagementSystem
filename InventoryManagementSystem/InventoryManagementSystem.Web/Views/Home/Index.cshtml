@model DashboardStatsServiceModel
@{
    ViewData["Title"] = "Dashboard";
}
<section class="hero rounded-4 p-5 mb-4">
    <h1 class="display-5 fw-bold">Inventory Management System</h1>
    <p class="lead">Track products, suppliers, warehouses and stock movements from one MVC application.</p>
    <a class="btn btn-primary btn-lg" asp-controller="Products" asp-action="Index">View Products</a>
</section>
<div class="row g-3">
    <div class="col-md-3"><div class="stat-card"><span>Products</span><strong>@Model.ProductsCount</strong></div></div>
    <div class="col-md-3"><div class="stat-card"><span>Low Stock</span><strong>@Model.LowStockCount</strong></div></div>
    <div class="col-md-3"><div class="stat-card"><span>Categories</span><strong>@Model.CategoriesCount</strong></div></div>
    <div class="col-md-3"><div class="stat-card"><span>Total Value</span><strong>@Model.TotalInventoryValue.ToString("C")</strong></div></div>
</div>
<div class="card mt-4">
    <div class="card-body">
        <h5>Live product search via AJAX API</h5>
        <input id="liveSearch" class="form-control" placeholder="Type at least 2 characters..." />
        <div id="liveSearchResults" class="list-group mt-3"></div>
    </div>
</div>
