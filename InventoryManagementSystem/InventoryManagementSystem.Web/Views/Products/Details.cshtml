@model Product
@{ ViewData["Title"] = Model.Name; }
<div class="card shadow-sm"><div class="card-body">
<h1>@Model.Name</h1>
<p class="text-muted">SKU: @Model.Sku</p>
<p>@Model.Description</p>
<dl class="row"><dt class="col-sm-3">Category</dt><dd class="col-sm-9">@Model.Category.Name</dd><dt class="col-sm-3">Supplier</dt><dd class="col-sm-9">@Model.Supplier.Name</dd><dt class="col-sm-3">Warehouse</dt><dd class="col-sm-9">@Model.Warehouse.Name</dd><dt class="col-sm-3">Price</dt><dd class="col-sm-9">@Model.Price.ToString("C")</dd><dt class="col-sm-3">Quantity</dt><dd class="col-sm-9">@Model.Quantity</dd></dl>
@if (User.Identity?.IsAuthenticated ?? false) { <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a> <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a> }
<a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div></div>
