@model IEnumerable<ProductListServiceModel>
<div class="table-responsive">
<table class="table table-hover align-middle">
<thead><tr><th>Name</th><th>SKU</th><th>Category</th><th>Supplier</th><th>Warehouse</th><th>Price</th><th>Qty</th><th></th></tr></thead>
<tbody>
@foreach (var item in Model)
{
    <tr class="@(item.IsLowStock ? "table-warning" : "")">
        <td>@item.Name</td><td>@item.Sku</td><td>@item.CategoryName</td><td>@item.SupplierName</td><td>@item.WarehouseName</td><td>@item.Price.ToString("C")</td><td>@item.Quantity</td>
        <td class="text-end"><a class="btn btn-sm btn-outline-secondary" asp-controller="Products" asp-action="Details" asp-route-id="@item.Id">Details</a></td>
    </tr>
}
</tbody>
</table>
</div>
