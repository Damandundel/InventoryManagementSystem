@model ProductQueryModel
@{ ViewData["Title"] = "Products"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Products</h1>
    @if (User.Identity?.IsAuthenticated ?? false) { <a class="btn btn-primary" asp-action="Create">Add Product</a> }
</div>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4"><input name="SearchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search name or SKU" /></div>
    <div class="col-md-3"><select name="Sorting" class="form-select"><option value="name">Name</option><option value="price_desc">Price desc</option><option value="quantity">Quantity asc</option><option value="quantity_desc">Quantity desc</option><option value="created_desc">Newest</option></select></div>
    <div class="col-md-2"><button class="btn btn-outline-primary w-100">Filter</button></div>
</form>
<partial name="_ProductTable" model="Model.Products" />
@{
    var totalPages = (int)Math.Ceiling((double)Model.TotalProducts / Model.ProductsPerPage);
}
@if (totalPages > 1)
{
    <nav><ul class="pagination">
    @for (int i = 1; i <= totalPages; i++)
    {
        <li class="page-item @(i == Model.CurrentPage ? "active" : "")"><a class="page-link" asp-route-CurrentPage="@i" asp-route-SearchTerm="@Model.SearchTerm" asp-route-Sorting="@Model.Sorting">@i</a></li>
    }
    </ul></nav>
}
