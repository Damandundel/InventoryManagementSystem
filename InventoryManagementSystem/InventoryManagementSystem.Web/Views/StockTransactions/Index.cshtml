@model IEnumerable<StockTransaction>
@{ ViewData["Title"] = "Stock Transactions"; }
<div class="d-flex justify-content-between"><h1>Stock Transactions</h1><a class="btn btn-primary" asp-action="Create">New Transaction</a></div>
<table class="table"><thead><tr><th>Date</th><th>Product</th><th>Type</th><th>Quantity</th><th>Note</th></tr></thead><tbody>@foreach(var item in Model){<tr><td>@item.CreatedOn.ToLocalTime()</td><td>@item.Product.Name</td><td>@item.Type</td><td>@item.Quantity</td><td>@item.Note</td></tr>}</tbody></table>
